# Top-level Gitignore for Java (Maven/Spring Boot) + Vue

# OS / filesystem artifacts
.DS_Store
Thumbs.db
desktop.ini

# Editor/IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.idea/
*.iml
*.iws
*.ipr

# Logs
*.log
logs/
backend/logs/
frontend/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment files
.env
.env.*
!.env.example
*.local
*.local.*

# Local Spring Boot overrides / secrets
backend/src/main/resources/application-local.properties
backend/src/main/resources/application-*.local.properties
backend/src/main/resources/application-secret.properties
backend/src/main/resources/application-secrets.properties
backend/src/test/resources/application-local.properties
backend/src/test/resources/application-*.local.properties

# Node/JS (frontend)
node_modules/
dist/
coverage/
.cache/
.temp/
*.tsbuildinfo

# Vue specific caches (if created)
vuepress/dist/

# Java/Maven (backend)
*.class
*.jar
*.war
*.ear
# Maven/Gradle build outputs
/target/
backend/target/
/.mvn/wrapper/.cache/
.gradle/
/build/
/bin/
/out/

# Test reports/build artifacts
surefire-reports/
jacoco.exec

# Misc
*.swp
*.swo
